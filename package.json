{
  "name": "specdown-cli",
  "version": "0.1.6",
  "description": "AI-native CLI for SpecDown — manage spec docs, sync Git, and connect AI assistants from your terminal",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "specdown": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "specdown",
    "cli",
    "docs",
    "markdown",
    "spec",
    "ai-native",
    "ai-native-cli",
    "mcp",
    "spec-as-code",
    "spec-driven",
    "markdown-cli",
    "ai-operable"
  ],
  "author": "SpecDown",
  "license": "MIT",
  "homepage": "https://specdown.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specdown-app/cli.git"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
